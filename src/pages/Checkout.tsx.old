import { Button } from "@/components/ui/button";
import { Card } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { Checkbox } from "@/components/ui/checkbox";
import { APP_LOGO } from "@/const";
import { Shield, Lock, Zap, Phone, Check } from "lucide-react";
import { useState, useEffect } from "react";
import { useLocation } from "wouter";
import { trpc } from "@/lib/trpc";
import { toast } from "sonner";
import { loadStripe } from "@stripe/stripe-js";
import { 
  Elements, 
  PaymentElement,
  useStripe, 
  useElements 
} from "@stripe/react-stripe-js";

// Initialize Stripe
const stripePromise = loadStripe(import.meta.env.VITE_STRIPE_PUBLISHABLE_KEY || "");

function PaymentForm({ 
  accountInfo, 
  billingAddress, 
  setBillingAddress,
  receiveUpdates, 
  currentPlan,
  checkoutType,
  billingInterval,
  detectedCountry,
  onSuccess,
  setupData,
  clientSecret
}: any) {
  const stripe = useStripe();
  const elements = useElements();
  const [isProcessing, setIsProcessing] = useState(false);

  const completeSetup = trpc.payment.completeSubscriptionSetup.useMutation({
    onSuccess: (data) => {
      toast.success("Payment successful! Welcome to Signova AI 🎉");
      setTimeout(() => {
        onSuccess();
      }, 1500);
    },
    onError: (error) => {
      toast.error(error.message || "Failed to complete setup");
      setIsProcessing(false);
    },
  });

  const completeCreditPurchase = trpc.payment.completeCreditPurchase.useMutation({
    onSuccess: (data) => {
      toast.success("Payment successful! Welcome to Signova AI 🎉");
      setTimeout(() => {
        onSuccess();
      }, 1500);
    },
    onError: (error) => {
      toast.error(error.message || "Failed to complete credit purchase");
      setIsProcessing(false);
    },
  });

  const purchaseCredits = trpc.payment.purchaseCredits.useMutation({
    onSuccess: async (data) => {
      if (!stripe || !elements) return;

      try {
        // Confirm payment with PaymentElement (handles all payment methods)
        const { error, paymentIntent } = await stripe.confirmPayment({
          elements,
          confirmParams: {
            return_url: `${window.location.origin}/checkout/success`,
          },
          redirect: 'if_required', // Don't redirect for card payments
        });

        if (error) {
          toast.error(error.message || "Payment failed");
          setIsProcessing(false);
          return;
        }

        if (paymentIntent?.status === "succeeded") {
          completeCreditPurchase.mutate({
            paymentIntentId: paymentIntent.id,
            customerId: data.customerId,
            accountInfo,
            billingAddress,
            credits: data.credits,
          });
        }
      } catch (error: any) {
        toast.error(error.message || "Payment failed");
        setIsProcessing(false);
      }
    },
    onError: (error) => {
      toast.error(error.message || "Failed to initiate payment");
      setIsProcessing(false);
    },
  });

  const createSubscription = trpc.payment.createSubscription.useMutation({
    onSuccess: async (data) => {
      if (!stripe || !elements) return;

      try {
        // Submit elements first (required for deferred intent)
        const { error: submitError } = await elements.submit();
        if (submitError) {
          toast.error(submitError.message || "Payment validation failed");
          setIsProcessing(false);
          return;
        }
        // Confirm setup with PaymentElement (handles all payment methods)
        const { error, setupIntent } = await stripe.confirmSetup({
          clientSecret: data.clientSecret,
          elements,
          confirmParams: {
            return_url: `${window.location.origin}/checkout/success`,
            payment_method_data: {
              billing_details: {
                name: accountInfo.fullName,
                email: accountInfo.email,
                phone: accountInfo.phone,
                address: {
                  line1: billingAddress.line1,
                  line2: billingAddress.line2 || undefined,
                  city: billingAddress.city,
                  state: billingAddress.state,
                  postal_code: billingAddress.postal_code,
                  country: billingAddress.country,
                },
              },
            },
          },
          redirect: 'if_required', // Don't redirect for card payments
        });

        if (error) {
          toast.error(error.message || "Payment setup failed");
          setIsProcessing(false);
          return;
        }

        if (setupIntent?.status === "succeeded") {
          completeSetup.mutate({
            setupIntentId: setupIntent.id,
            subscriptionId: data.subscriptionId,
            customerId: data.customerId,
            accountInfo,
            billingAddress,
            planId: currentPlan.planId,
          });
        }
      } catch (error: any) {
        toast.error(error.message || "Payment setup failed");
        setIsProcessing(false);
      }
    },
    onError: (error) => {
      toast.error(error.message || "Failed to create subscription");
      setIsProcessing(false);
    },
  });

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    
    if (!stripe || !elements) {
      toast.error("Payment system not ready. Please refresh the page.");
      return;
    }

    setIsProcessing(true);

    if (checkoutType === 'credits') {
      // For credit purchases
      purchaseCredits.mutate({
        accountInfo,
        billingAddress,
        credits: currentPlan.credits || 50,
        amount: parseFloat(currentPlan.price.replace('$', '')),
      });
    } else {
      // For subscriptions
      createSubscription.mutate({
        accountInfo,
        billingAddress,
        planId: currentPlan.planId,
        interval: billingInterval,
        receiveUpdates,
      });
    }
  };

  return (
    <form onSubmit={handleSubmit} className="space-y-6">
      {/* Billing Address */}
      <Card className="p-6 shadow-lg">
        <h3 className="text-xl font-semibold mb-4">Billing Address</h3>
        <p className="text-sm text-gray-600 mb-4">
          Enter your billing address for payment verification and account setup.
        </p>
        <div className="space-y-4">
          {/* Country */}
          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">
              Country *
            </label>
            <select
              value={billingAddress.country || detectedCountry || 'US'}
              onChange={(e) => setBillingAddress({...billingAddress, country: e.target.value})}
              className="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-500"
              required
            >
              <option value="US">United States</option>
              <option value="CA">Canada</option>
              <option value="GB">United Kingdom</option>
              <option value="AU">Australia</option>
              <option value="DE">Germany</option>
              <option value="FR">France</option>
              <option value="IT">Italy</option>
              <option value="ES">Spain</option>
              <option value="NL">Netherlands</option>
              <option value="SE">Sweden</option>
              <option value="NO">Norway</option>
              <option value="DK">Denmark</option>
              <option value="FI">Finland</option>
              <option value="IE">Ireland</option>
              <option value="NZ">New Zealand</option>
              <option value="SG">Singapore</option>
              <option value="JP">Japan</option>
              <option value="KR">South Korea</option>
            </select>
          </div>

          {/* Address Line 1 */}
          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">
              Address Line 1 *
            </label>
            <input
              type="text"
              value={billingAddress.line1 || ''}
              onChange={(e) => setBillingAddress({...billingAddress, line1: e.target.value})}
              placeholder="Street address, P.O. box"
              className="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-500"
              required
            />
          </div>

          {/* Address Line 2 */}
          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">
              Address Line 2
            </label>
            <input
              type="text"
              value={billingAddress.line2 || ''}
              onChange={(e) => setBillingAddress({...billingAddress, line2: e.target.value})}
              placeholder="Apartment, suite, unit, building, floor, etc."
              className="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-500"
            />
          </div>

          {/* City and State/Province Row */}
          <div className="grid grid-cols-2 gap-4">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">
                City *
              </label>
              <input
                type="text"
                value={billingAddress.city || ''}
                onChange={(e) => setBillingAddress({...billingAddress, city: e.target.value})}
                placeholder="City"
                className="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-500"
                required
              />
            </div>
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">
                {billingAddress.country === 'US' || billingAddress.country === 'CA' ? 'State/Province' : 'State/Region'} *
              </label>
              <input
                type="text"
                value={billingAddress.state || ''}
                onChange={(e) => setBillingAddress({...billingAddress, state: e.target.value})}
                placeholder={billingAddress.country === 'US' ? 'CA' : 'State'}
                className="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-500"
                required
              />
            </div>
          </div>

          {/* Postal Code */}
          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">
              {billingAddress.country === 'US' ? 'ZIP Code' : 'Postal Code'} *
            </label>
            <input
              type="text"
              value={billingAddress.postal_code || ''}
              onChange={(e) => setBillingAddress({...billingAddress, postal_code: e.target.value})}
              placeholder={billingAddress.country === 'US' ? '12345' : 'Postal code'}
              className="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-500"
              required
            />
          </div>
        </div>
      </Card>

      {/* Payment Method */}
      <Card className="p-6 shadow-lg">
        <h3 className="text-xl font-semibold mb-4">Payment Method</h3>
        <p className="text-sm text-gray-600 mb-4">
          {checkoutType === 'credits' 
            ? 'Enter your payment details below. Your card will be charged immediately.'
            : (currentPlan.planId === 'business'
                ? 'Enter your payment details below. Your card will not be charged during the 7-day free trial.'
                : 'Enter your payment details below. Your card will be charged immediately. 30-day money-back guarantee applies.')
          }
        </p>

        <div className="mb-4">
          <PaymentElement 
            options={{
              layout: {
                type: 'tabs',
                defaultCollapsed: false,
              },
              paymentMethodOrder: ['apple_pay', 'google_pay', 'card'],
              defaultValues: {
                billingDetails: {
                  name: accountInfo.fullName,
                  email: accountInfo.email,
                  phone: accountInfo.phone,
                  address: {
                    line1: billingAddress.line1,
                    line2: billingAddress.line2,
                    city: billingAddress.city,
                    state: billingAddress.state,
                    postal_code: billingAddress.postal_code,
                    country: billingAddress.country,
                  },
                },
              },
              fields: {
                billingDetails: {
                  name: 'never',  // Already collected in Account Information
                  email: 'never', // Already collected in Account Information
                  phone: 'never', // Already collected in Account Information
                  address: 'never',  // Already collected in Billing Address section
                }
              },
              wallets: {
                applePay: 'auto',
                googlePay: 'auto',
              },
              terms: {
                card: 'auto',
              },
            }}
          />
        </div>

        <div className="space-y-2">
          <div className="flex items-center gap-2 text-sm text-gray-600">
            <Lock className="h-4 w-4" />
            <span>Secured by Stripe • PCI DSS Level 1 Certified</span>
          </div>
          <div className="flex items-center gap-2 text-sm text-green-600">
            <Check className="h-4 w-4" />
            <span>Supports Apple Pay, Google Pay, and 150+ payment methods worldwide</span>
          </div>
        </div>
      </Card>

      {/* Submit Button */}
      <Button
        type="submit"
        disabled={isProcessing || !stripe}
        className="w-full bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-700 hover:to-blue-700 text-white py-6 text-lg font-semibold"
      >
        {isProcessing ? (
          <span className="flex items-center gap-2">
            <div className="animate-spin h-5 w-5 border-2 border-white border-t-transparent rounded-full"></div>
            Processing...
          </span>
        ) : checkoutType === 'credits' ? (
          `Pay ${currentPlan.price}`
        ) : currentPlan.planId === 'business' ? (
          'Start 7-Day Free Trial'
        ) : billingInterval === 'year' ? (
          `Subscribe for ${currentPlan.yearlyPrice}/year`
        ) : (
          `Subscribe for ${currentPlan.price}/month`
        )}
      </Button>

      <p className="text-xs text-center text-gray-500">
        By clicking "{checkoutType === 'credits' ? 'Pay' : 'Subscribe'}", you agree to our Terms of Service and Privacy Policy
      </p>
    </form>
  );
}

export default function Checkout() {
  const [location, setLocation] = useLocation();
  const searchParams = new URLSearchParams(window.location.search);
  
  const planParam = searchParams.get('plan') || 'professional';
  const priceParam = searchParams.get('price') || '$29';
  const checkoutType = searchParams.get('type') || 'subscription';
  
  const [accountInfo, setAccountInfo] = useState({
    fullName: "",
    email: "",
    phone: "",
    company: "",
  });

  const [billingAddress, setBillingAddress] = useState({
    line1: "",
    line2: "",
    city: "",
    state: "",
    postal_code: "",
    country: "",
  });

  const [agreeToTerms, setAgreeToTerms] = useState(false);
  const [receiveUpdates, setReceiveUpdates] = useState(false);
  const [canShowPayment, setCanShowPayment] = useState(false);
  const [clientSecret, setClientSecret] = useState<string | null>(null);
  const [setupData, setSetupData] = useState<{customerId: string; setupIntentId: string} | null>(null);
  
  // Initialize SetupIntent when user agrees to terms
  const initSetupIntent = trpc.payment.initializeSetupIntent.useMutation({
    onSuccess: (data) => {
      setClientSecret(data.clientSecret);
      setSetupData({ customerId: data.customerId, setupIntentId: data.setupIntentId });
    },
    onError: (error) => {
      toast.error("Failed to initialize payment: " + error.message);
    },
  });

  const [billingInterval, setBillingInterval] = useState<'month' | 'year'>('month');
  const [detectedCountry, setDetectedCountry] = useState<string>('');

  // Detect country from IP on component mount
  useEffect(() => {
    fetch('https://ipapi.co/json/')
      .then(res => res.json())
      .then(data => {
        if (data.country_code) {
          setDetectedCountry(data.country_code);
          setBillingAddress(prev => ({ ...prev, country: data.country_code }));
        }
      })
      .catch(err => {
        console.log('Could not detect country:', err);
        // Default to US if detection fails
        setDetectedCountry('US');
        setBillingAddress(prev => ({ ...prev, country: 'US' }));
      });
  }, []);

  // Validation
  useEffect(() => {
    const isValid = 
      accountInfo.fullName.trim() !== "" &&
      accountInfo.email.trim() !== "" &&
      accountInfo.phone.trim() !== "" &&
      agreeToTerms;
    
    setCanShowPayment(isValid);
  }, [accountInfo, agreeToTerms]);

  // Fetch clientSecret when form is valid
  useEffect(() => {
    if (canShowPayment && !clientSecret && !initSetupIntent.isPending) {
      initSetupIntent.mutate({ planId: currentPlan.planId, email: accountInfo.email });
    }
  }, [canShowPayment, clientSecret, accountInfo.email, accountInfo.fullName]);

  const currentPlan = {
    planId: planParam.toLowerCase(),
    name: planParam.charAt(0).toUpperCase() + planParam.slice(1),
    price: priceParam,
    yearlyPrice: getYearlyPrice(priceParam),
    credits: checkoutType === 'credits' ? parseInt(searchParams.get('credits') || '50') : undefined,
  };

  function getYearlyPrice(monthlyPrice: string): string {
    const monthly = parseFloat(monthlyPrice.replace('$', ''));
    const yearly = Math.round(monthly * 10); // 10 months price for 12 months (2 months free)
    return `$${yearly}`;
  }

  const handleSuccess = () => {
    setLocation('/dashboard');
  };

  const returnedClientSecret = searchParams.get('payment_intent_client_secret') || 
                       searchParams.get('setup_intent_client_secret');

  return (
    <div className="min-h-screen bg-gradient-to-br from-purple-50 via-white to-blue-50">
      {/* Header */}
      <div className="bg-white border-b shadow-sm">
        <div className="max-w-7xl mx-auto px-6 py-6 flex items-center justify-between">
          <img 
            src="/logo-horizontal.png" 
            alt="Signova AI" 
            className="h-24 object-contain"
            style={{ maxWidth: '400px' }}
          />
          <Button 
            variant="ghost" 
            onClick={() => setLocation('/pricing')}
            className="text-gray-600 hover:text-gray-900 font-medium"
          >
            ← Back to Pricing
          </Button>
        </div>
      </div>

      <div className="max-w-4xl mx-auto px-4 py-12">
        <div className="text-center mb-8">
          <h1 className="text-4xl font-bold bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent mb-2">
            {checkoutType === 'credits' ? 'Purchase Credits' : `Subscribe to ${currentPlan.name}`}
          </h1>
          <p className="text-gray-600">
            {checkoutType === 'credits' 
              ? `Get ${currentPlan.credits} document credits for ${currentPlan.price}`
              : billingInterval === 'year'
                ? `${currentPlan.yearlyPrice}/year (Save 16% - Get 2 months free!)`
                : `${currentPlan.price}/month`
            }
          </p>
        </div>

        {/* Billing Interval Toggle (only for subscriptions) */}
        {checkoutType === 'subscription' && currentPlan.planId !== 'enterprise' && (
          <Card className="p-6 shadow-lg mb-6">
            <div className="flex items-center justify-between">
              <div>
                <h3 className="text-lg font-semibold mb-1">Billing Frequency</h3>
                <p className="text-sm text-gray-600">Save 16% when you pay annually</p>
              </div>
              <div className="flex items-center gap-4 bg-gray-100 rounded-lg p-1">
                <button
                  type="button"
                  onClick={() => setBillingInterval('month')}
                  className={`px-6 py-2 rounded-md font-medium transition-all ${
                    billingInterval === 'month'
                      ? 'bg-white text-purple-600 shadow-sm'
                      : 'text-gray-600 hover:text-gray-900'
                  }`}
                >
                  Monthly
                </button>
                <button
                  type="button"
                  onClick={() => setBillingInterval('year')}
                  className={`px-6 py-2 rounded-md font-medium transition-all ${
                    billingInterval === 'year'
                      ? 'bg-white text-purple-600 shadow-sm'
                      : 'text-gray-600 hover:text-gray-900'
                  }`}
                >
                  <span className="flex items-center gap-2">
                    Yearly
                    <span className="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full">
                      Save 16%
                    </span>
                  </span>
                </button>
              </div>
            </div>
          </Card>        )}

        {/* Plan Features Summary */}
        {checkoutType === 'subscription' && (
          <Card className="p-6 shadow-lg mb-6 bg-gradient-to-br from-purple-50 to-blue-50">
            <h3 className="text-lg font-semibold mb-4 text-center">What's Included in {currentPlan.name}</h3>
            <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
              {currentPlan.planId === 'starter' && (
                <>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">10 e-signatures per month</span>
                  </div>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">5 AI-generated documents</span>
                  </div>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">Basic templates library</span>
                  </div>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">Email support (24-48hr)</span>
                  </div>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">256-bit encryption</span>
                  </div>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">Audit trails</span>
                  </div>
                </>
              )}
              {currentPlan.planId === 'professional' && (
                <>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">50 e-signatures per month</span>
                  </div>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">25 AI-generated documents</span>
                  </div>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">Custom templates (save & reuse)</span>
                  </div>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">Team collaboration (up to 5 users)</span>
                  </div>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">Priority support (12-24hr)</span>
                  </div>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">Custom branding & API access</span>
                  </div>
                </>
              )}
              {currentPlan.planId === 'business' && (
                <>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">200 e-signatures per month</span>
                  </div>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">100 AI-generated documents</span>
                  </div>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">Unlimited custom templates</span>
                  </div>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">Team collaboration (up to 20 users)</span>
                  </div>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">Priority support (4-8hr)</span>
                  </div>
                  <div className="flex items-start gap-2">
                    <Check className="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" />
                    <span className="text-sm text-gray-700">White-label branding & SSO</span>
                  </div>
                </>
              )}
            </div>
          </Card>
        )}

        {/* Account Information */}
        <Card className="p-6 shadow-lg mb-6">         <h3 className="text-xl font-semibold mb-4">Account Information</h3>
          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-2">
                Full Name *
              </label>
              <Input
                type="text"
                value={accountInfo.fullName}
                onChange={(e) => setAccountInfo({ ...accountInfo, fullName: e.target.value })}
                placeholder="John Doe"
                required
              />
            </div>
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-2">
                Email Address *
              </label>
              <Input
                type="email"
                value={accountInfo.email}
                onChange={(e) => setAccountInfo({ ...accountInfo, email: e.target.value })}
                placeholder="john@company.com"
                required
              />
            </div>
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-2">
                Phone Number *
              </label>
              <Input
                type="tel"
                value={accountInfo.phone}
                onChange={(e) => setAccountInfo({ ...accountInfo, phone: e.target.value })}
                placeholder="+1 (555) 123-4567"
                required
              />
            </div>
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-2">
                Company (Optional)
              </label>
              <Input
                type="text"
                value={accountInfo.company}
                onChange={(e) => setAccountInfo({ ...accountInfo, company: e.target.value })}
                placeholder="Acme Inc."
              />
            </div>
          </div>

          <div className="mt-6 space-y-3">
            <div className="flex items-start gap-2">
              <Checkbox
                id="terms"
                checked={agreeToTerms}
                onCheckedChange={(checked) => setAgreeToTerms(checked as boolean)}
                required
              />
              <label htmlFor="terms" className="text-sm text-gray-700 cursor-pointer">
                I agree to the <a href="/terms" className="text-purple-600 hover:underline">Terms of Service</a> and <a href="/privacy" className="text-purple-600 hover:underline">Privacy Policy</a> *
              </label>
            </div>
            <div className="flex items-start gap-2">
              <Checkbox
                id="updates"
                checked={receiveUpdates}
                onCheckedChange={(checked) => setReceiveUpdates(checked as boolean)}
              />
              <label htmlFor="updates" className="text-sm text-gray-700 cursor-pointer">
                Send me product updates and special offers
              </label>
            </div>
          </div>
        </Card>

        {/* Payment Form - Only show when account info is complete */}
        {canShowPayment && clientSecret && (
          
          <Elements 
            stripe={stripePromise}
            options={{
              clientSecret,
              appearance: {
                theme: 'stripe',
                variables: {
                  colorPrimary: '#7c3aed',
                  colorBackground: '#ffffff',
                  colorText: '#1f2937',
                  colorDanger: '#dc2626',
                  fontFamily: 'system-ui, -apple-system, sans-serif',
                  borderRadius: '8px',
                },
              },
            }}
          >
            <PaymentForm
              accountInfo={accountInfo}
              billingAddress={billingAddress}
              setBillingAddress={setBillingAddress}
              receiveUpdates={receiveUpdates}
              currentPlan={currentPlan}
              checkoutType={checkoutType}
              billingInterval={billingInterval}
              detectedCountry={detectedCountry}
              onSuccess={handleSuccess}
              setupData={setupData}
              clientSecret={clientSecret}
            />
          </Elements>
        )}

        {/* Security Badges */}
        <div className="mt-8 flex flex-wrap items-center justify-center gap-6 text-sm text-gray-600">
          <div className="flex items-center gap-2">
            <Shield className="h-5 w-5 text-green-600" />
            <span>256-bit SSL Encryption</span>
          </div>
          <div className="flex items-center gap-2">
            <Lock className="h-5 w-5 text-green-600" />
            <span>PCI DSS Compliant</span>
          </div>
          <div className="flex items-center gap-2">
            <Zap className="h-5 w-5 text-green-600" />
            <span>Instant Activation</span>
          </div>
        </div>

        {/* Payment Methods */}
        <div className="mt-8 text-center">
          <p className="text-sm text-gray-600 mb-4 font-medium">Secure Payment Methods Accepted</p>
          <div className="flex flex-wrap items-center justify-center gap-3">
            <img src="/payment-cards.jpg" alt="Visa, Mastercard, Amex, Discover" className="h-8 object-contain" />
            <img src="/payment-digital.jpg" alt="Apple Pay, Google Pay" className="h-8 object-contain" />
          </div>
          <p className="text-xs text-gray-500 mt-2">+ Link, Klarna, Affirm, Amazon Pay, and more</p>
        </div>

        {/* Money-back Guarantee */}
        <div className="mt-6 text-center">
          <p className="text-sm text-gray-600">
            <strong>30-Day Money-Back Guarantee</strong> - If you're not satisfied, we'll refund your payment. No questions asked.
          </p>
        </div>

        {/* FAQ Section */}
        <Card className="mt-8 p-6 shadow-lg">
          <h3 className="text-xl font-semibold mb-4 text-center">Frequently Asked Questions</h3>
          <div className="space-y-4">
            <div>
              <h4 className="font-medium text-gray-900 mb-1">Can I cancel anytime?</h4>
              <p className="text-sm text-gray-600">Yes! Cancel anytime with no penalties or fees. Your subscription remains active until the end of your billing period.</p>
            </div>
            <div>
              <h4 className="font-medium text-gray-900 mb-1">What payment methods do you accept?</h4>
              <p className="text-sm text-gray-600">We accept all major credit cards (Visa, Mastercard, Amex, Discover), Apple Pay, Google Pay, Link, Amazon Pay, and buy-now-pay-later options like Klarna and Affirm.</p>
            </div>
            <div>
              <h4 className="font-medium text-gray-900 mb-1">Is my payment information secure?</h4>
              <p className="text-sm text-gray-600">Absolutely. We use Stripe for payment processing with 256-bit SSL encryption and are PCI DSS compliant. We never store your card details on our servers.</p>
            </div>
            <div>
              <h4 className="font-medium text-gray-900 mb-1">When does my subscription start?</h4>
              <p className="text-sm text-gray-600">Your subscription activates instantly upon payment confirmation. You'll get immediate access to all features.</p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  );
}
